# Copy this file to `.env` and fill in the credentials you want to use locally.

# Shared staging location selector labels for
# NEXUDUS_AP_LOCATION_SELECTOR_LABEL and NEXUDUS_MP_LOCATION_SELECTOR_LABEL:
# - Coworking Network (STEVEN)
# - Coworking Central Street (STEVEN)
# - Coworking Soho (STEVEN)

# Required for AP Playwright coverage, the AP-backed BDD meeting-room seed utility,
# and the AP k6 login smoke test.
# AP credentials
NEXUDUS_AP_EMAIL=
NEXUDUS_AP_PASSWORD=
NEXUDUS_AP_MEMBER_NAME=Felicity Ward
NEXUDUS_AP_RECEIVED_BY_NAME=Steven Hobbs
NEXUDUS_AP_LOCATION_SELECTOR_LABEL=Coworking Soho (STEVEN)

# Required default member credentials for MP-staging Playwright coverage.
# Use these for a member or coworker account. Keep contact-user credentials in
# NEXUDUS_CONTACT_* below so member and contact roles stay distinct.
# Uses the same shared staging location labels listed above.
NEXUDUS_MP_EMAIL=
NEXUDUS_MP_PASSWORD=
NEXUDUS_MP_LOCATION_SELECTOR_LABEL=Coworking Soho (STEVEN)

# Optional role-based credentials for tests that need specific user types.
# Admin falls back to the AP credentials above when these are left blank.
NEXUDUS_ADMIN_EMAIL=
NEXUDUS_ADMIN_PASSWORD=

# Member falls back to the default MP member credentials above when these are left blank.
NEXUDUS_MEMBER_EMAIL=
NEXUDUS_MEMBER_PASSWORD=

# Optional BDD booking resolver fallback when a member email can be looked up by
# full display name but the member uses the shared default password.
NEXUDUS_MEMBER_DEFAULT_PASSWORD=

# Optional MP booking utility action for the BDD booking outline.
# Leave blank to use the default `add` mode. Set to `delete` to cancel the
# booking ids stored by the most recent add run for each example row.
NEXUDUS_BDD_BOOKING_ACTION=

# Optional fallback booking utility mode for the BDD booking outline.
# The current feature file sets `mp` or `ap` per example row in Gherkin.
# Leave blank to use the default `mp` mode only when a utility scenario does
# not provide its own mode step.
NEXUDUS_BDD_BOOKING_MODE=

# Optional per-member BDD overrides use the pattern below. Replace BOB_YOUNGER
# with the member's uppercase snake-case display name.
# NEXUDUS_MEMBER_BOB_YOUNGER_EMAIL=
# NEXUDUS_MEMBER_BOB_YOUNGER_PASSWORD=

# Contact does not have a fallback and should be set explicitly when needed.
NEXUDUS_CONTACT_EMAIL=
NEXUDUS_CONTACT_PASSWORD=

# Optional API credential overrides. By default the API tests use the MP host origin and MP credentials.
NEXUDUS_API_USERNAME=
NEXUDUS_API_PASSWORD=

# Optional URL overrides. Leave the MP/API values blank to derive them from
# `NEXUDUS_MP_LOCATION_SELECTOR_LABEL`.
NEXUDUS_AP_BASE_URL=https://dashboard-staging.nexudus.com/
NEXUDUS_MP_BASE_URL=
NEXUDUS_API_BASE_URL=

# Optional Lighthouse thresholds for the authenticated AP and MP audits.
LIGHTHOUSE_MIN_PERFORMANCE=35
LIGHTHOUSE_MIN_ACCESSIBILITY=55
LIGHTHOUSE_MIN_BEST_PRACTICES=50
