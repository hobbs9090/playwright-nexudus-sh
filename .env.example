# Copy this file to `.env` and fill in the credentials you want to use locally.

# Required for AP Playwright coverage and the AP k6 login smoke test.
# AP credentials
NEXUDUS_AP_EMAIL=
NEXUDUS_AP_PASSWORD=
NEXUDUS_AP_MEMBER_NAME=Felicity Ward
NEXUDUS_AP_RECEIVED_BY_NAME=Steven Hobbs

# Required for MP-staging Playwright coverage.
# MP staging credentials
NEXUDUS_MP_EMAIL=
NEXUDUS_MP_PASSWORD=

# Optional role-based credentials for tests that need specific user types.
# Admin falls back to the AP credentials above when these are left blank.
NEXUDUS_ADMIN_EMAIL=
NEXUDUS_ADMIN_PASSWORD=

# Member falls back to the MP credentials above when these are left blank.
NEXUDUS_MEMBER_EMAIL=
NEXUDUS_MEMBER_PASSWORD=

# Contact does not have a fallback and should be set explicitly when needed.
NEXUDUS_CONTACT_EMAIL=
NEXUDUS_CONTACT_PASSWORD=

# Optional API overrides. By default the API tests use the MP host origin and MP credentials.
NEXUDUS_API_BASE_URL=
NEXUDUS_API_USERNAME=
NEXUDUS_API_PASSWORD=

# Optional URL overrides. Leave these as-is unless you need a different target host.
NEXUDUS_AP_BASE_URL=https://dashboard-staging.nexudus.com/
NEXUDUS_MP_BASE_URL=https://coworkingnetworksteven.spacesstaging.nexudus.com/

# Optional Lighthouse thresholds for the authenticated AP and MP audits.
LIGHTHOUSE_MIN_PERFORMANCE=35
LIGHTHOUSE_MIN_ACCESSIBILITY=60
LIGHTHOUSE_MIN_BEST_PRACTICES=50
